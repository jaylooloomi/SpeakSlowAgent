{
  "name": "speakslow",
  "version": "1.0.0",
  "description": "聲聲慢 - 基於 FunASR 和可配置 AI 模型的繁體中文語音轉文字應用",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "node start-electron.js",
    "dev": "concurrently -k -r \"npm:dev:renderer\" \"npm:dev:main\"",
    "dev:main": "cross-env NODE_ENV=development electronmon .",
    "dev:renderer": "cd src && vite",
    "build": "cd src && vite build && cd .. && electron-builder",
    "postinstall": "electron-builder install-app-deps",
    "build:renderer": "cd src && vite build",
    "prepare:python": "pip install sherpa-onnx numpy opencc pyinstaller && python download_all_models.py",
    "build:backend": "python -m PyInstaller --onedir --noconfirm --clean --collect-all sherpa_onnx --collect-all opencc --distpath build_pyi/dist --workpath build_pyi/work --specpath build_pyi sherpa_server.py",
    "build:win": "electron-builder --win",
    "dist:win": "npm run build:backend && npm run build:renderer && electron-builder --win",
    "lint": "cd src && eslint .",
    "preview": "cd src && vite preview",
    "clean": "node cleanup.js && rm -rf python"
  },
  "electronmon": {
    "patterns": [
      "!dist/**",
      "!build_pyi/**",
      "!build/**",
      "!web/**",
      "!poc-sherpa/**",
      "!assets/logo-build/**",
      "!.venv/**"
    ]
  },
  "keywords": [
    "dictation",
    "speech-to-text",
    "funasr",
    "ai",
    "llm",
    "chinese",
    "electron",
    "desktop-app"
  ],
  "author": {
    "name": "yan5xu",
    "email": "lueco.x@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron/notarize": "^3.0.1",
    "@eslint/js": "^9.25.0",
    "@tailwindcss/postcss": "^4.1.13",
    "@tailwindcss/vite": "^4.1.10",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.2",
    "cross-env": "^10.0.0",
    "electron": "^31.7.7",
    "electron-builder": "^24.6.4",
    "electronmon": "^2.0.4",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "node-gyp": "^11.4.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.10",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.12",
    "asynckit": "^0.4.0",
    "axios": "^1.6.0",
    "better-sqlite3": "^11.10.0",
    "bindings": "^1.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "combined-stream": "^1.0.8",
    "delayed-stream": "^1.0.0",
    "dotenv": "^16.3.1",
    "electron-updater": "^6.6.2",
    "es-errors": "^1.3.0",
    "es-object-atoms": "^1.1.1",
    "es-set-tostringtag": "^2.1.0",
    "ffmpeg-static": "^5.2.0",
    "file-uri-to-path": "^2.0.0",
    "form-data": "^4.0.4",
    "get-intrinsic": "^1.3.0",
    "lucide-react": "^0.518.0",
    "math-intrinsics": "^1.1.0",
    "mime-db": "^1.54.0",
    "mime-types": "^3.0.1",
    "next-themes": "^0.4.6",
    "opencc-js": "^1.0.5",
    "osascript": "^1.0.7",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "shadcn-ui": "^0.9.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "tar": "^7.4.3",
    "tw-animate-css": "^1.3.4",
    "uiohook-napi": "^1.5.4",
    "unzipper": "^0.12.3"
  },
  "build": {
    "appId": "com.speakslow.app",
    "productName": "SpeakSlow",
    "npmRebuild": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "sherpa_server.py",
      "package.json",
      "node_modules/**/*",
      "src/dist/**/*",
      "src/helpers/**/*",
      "src/utils/**/*",
      "assets/**/*",
      "!node_modules/.cache/**/*",
      "!src/node_modules/**/*"
    ],
    "asarUnpack": [
      "sherpa_server.py",
      "node_modules/**/*ffmpeg-static*/**/*",
      "node_modules/**/*better-sqlite3*/**/*",
      "node_modules/**/*bindings*/**/*"
    ],
    "extraResources": [
      {
        "from": "build_pyi/dist/sherpa_server",
        "to": "sherpa-backend"
      },
      {
        "from": "poc-sherpa/sherpa-onnx-paraformer-zh-2023-09-14",
        "to": "sherpa-backend/poc-sherpa/sherpa-onnx-paraformer-zh-2023-09-14"
      },
      {
        "from": "poc-sherpa/sherpa-onnx-punct-ct-transformer-zh-en-vocab272727-2024-04-12",
        "to": "sherpa-backend/poc-sherpa/sherpa-onnx-punct-ct-transformer-zh-en-vocab272727-2024-04-12"
      },
      {
        "from": "poc-sherpa/silero_vad.onnx",
        "to": "sherpa-backend/poc-sherpa/silero_vad.onnx"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "notarize": {
        "teamId": "7MTHK6DGS4"
      }
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "聲聲慢",
      "include": "build/installer.nsh"
    },
    "linux": {
      "icon": "assets/icon.png",
      "category": "Office"
    }
  }
}
